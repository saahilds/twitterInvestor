APP_NAME=twitter-trade-bot
DATABASE_URL=sqlite:///./trading_bot.db

TARGET_ACCOUNT=CKCapitalxx
POLL_INTERVAL_SECONDS=7
FETCH_LIMIT=20
IGNORE_REPLIES=true
IGNORE_RETWEETS=true
TWITTER_BACKEND=playwright
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=20000
PLAYWRIGHT_USER_DATA_DIR=.playwright/x-profile
PLAYWRIGHT_CHANNEL=chrome
PLAYWRIGHT_CDP_URL=
PLAYWRIGHT_REQUIRE_LOGIN=true
PLAYWRIGHT_LOGIN_TIMEOUT_SECONDS=300
BACKFILL_MAX_SCROLLS=150
BACKFILL_SCROLL_PAUSE_MS=1500

ALLOWED_TICKERS=AAPL,MSFT,NVDA,TSLA,META,AMZN,GOOGL,AMD,QQQ,SPY
DEFAULT_TRADE_SIZE_USD=1.0
MAX_TRADE_SIZE_USD=5.0
COOLDOWN_SECONDS=300
DUPLICATE_WINDOW_SECONDS=300

SIMULATION_MODE=true
ENABLE_LIVE_TRADING=false
BROKER_BACKEND=robinhood
ORDER_EXECUTION_MODE=limit_at_ask
TRADING_WINDOW_ENABLED=true
US_SYMBOLS_ONLY=true
MAX_TRADES_PER_TICKER_PER_DAY=1
DAILY_LIMIT_COUNTS_SIMULATION=false

ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# not needed for most accounts
# ROBINHOOD_MFA_SECRET=
# individual, joint, or exact account_number (see: uv run python -m app.cli.rh_login --list-accounts)
ROBINHOOD_ACCOUNT=individual

LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
