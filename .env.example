APP_NAME=twitter-trade-bot
DATABASE_URL=sqlite:///./trading_bot.db

TARGET_ACCOUNT=CKCapitalxx
POLL_INTERVAL_SECONDS=60
# Robinhood holdings + chart snapshots on the dashboard (seconds)
DASHBOARD_POSITIONS_REFRESH_SECONDS=300
FETCH_LIMIT=20
IGNORE_REPLIES=true
IGNORE_RETWEETS=true
TWITTER_BACKEND=playwright
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_PROFILE_LOAD_RETRIES=3
PLAYWRIGHT_USER_DATA_DIR=.playwright/x-profile
PLAYWRIGHT_CHANNEL=chrome
PLAYWRIGHT_CDP_URL=
PLAYWRIGHT_REQUIRE_LOGIN=true
PLAYWRIGHT_LOGIN_TIMEOUT_SECONDS=300
BACKFILL_MAX_SCROLLS=150
BACKFILL_SCROLL_PAUSE_MS=1500

# Seeds recognized_tickers at startup only; confident BUY signals still execute for other US tickers
ALLOWED_TICKERS=AAPL,MSFT,NVDA,TSLA,META,AMZN,GOOGL,AMD,QQQ,SPY
# Optional floor for BUY on tickers not in ALLOWED_TICKERS (0 = off)
MIN_BUY_CONFIDENCE_UNLISTED=0
# Default sell size when tweet does not specify % (trim=25%, half=50%, closed/sell=100%)
DEFAULT_SELL_FRACTION=1.0
MIN_SELL_NOTIONAL_USD=1.0
DEFAULT_TRADE_SIZE_USD=100.0
MAX_TRADE_SIZE_USD=1000.0
THESIS_TRADE_MIN_USD=500.0
THESIS_TRADE_MAX_USD=1000.0
CASH_BUFFER_USD=0
MIN_BUY_NOTIONAL_USD=1.0
NEW_TICKER_SIZE_MULTIPLIER=10
COOLDOWN_SECONDS=300
DUPLICATE_WINDOW_SECONDS=300

# keywords = phrase list only; hybrid = keywords + local TF-IDF model (no LLM API)
SIGNAL_PARSER_BACKEND=hybrid
SIGNAL_ML_MIN_CONFIDENCE=0.42
SIGNAL_ML_MIN_MARGIN=0.08

CHART_YTD_BASELINE_USD=5000.0

SIMULATION_MODE=true
ENABLE_LIVE_TRADING=false
BROKER_BACKEND=robinhood
ORDER_EXECUTION_MODE=limit_at_ask
TRADING_WINDOW_ENABLED=true
US_SYMBOLS_ONLY=true
MAX_TRADES_PER_TICKER_PER_DAY=1
DAILY_LIMIT_COUNTS_SIMULATION=false

ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# not needed for most accounts
# ROBINHOOD_MFA_SECRET=
# individual, joint, or exact account_number (see: uv run python -m app.cli.rh_login --list-accounts)
ROBINHOOD_ACCOUNT=individual
# Comma-separated account managers (each maps to robinhood_account selector by default)
# BOT_MANAGERS=individual,joint
# When multiple managers are listed, only ROBINHOOD_ACCOUNT trades by default.
# Set BOT_MANAGERS_ENABLE_ALL=true to fan out to every manager.
# Or mark one off explicitly: BOT_MANAGERS=individual:disabled,joint
# BOT_MANAGERS_ENABLE_ALL=false
# Back off after failed login (seconds); 429 responses use the longer backoff below
ROBINHOOD_LOGIN_RETRY_SECONDS=300
ROBINHOOD_LOGIN_429_BACKOFF_SECONDS=900
ROBINHOOD_SESSION_VALIDATE_SECONDS=120

PNL_INCLUDE_SIMULATION=true
PNL_QUOTE_CACHE_SECONDS=60

LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# --- VPS / Docker (Hetzner CX32) ---
# Copy .env to the server only (scp); chmod 600 .env. See docs/VPS.md.
#
# Playwright on VPS (Dockerfile sets chromium + headless; override Mac chrome settings):
# PLAYWRIGHT_HEADLESS=true
# PLAYWRIGHT_CHANNEL=chromium
# PLAYWRIGHT_CDP_URL=
# PLAYWRIGHT_REQUIRE_LOGIN=false
# PLAYWRIGHT_USER_DATA_DIR=.playwright/x-profile
#
# Robinhood push-only MFA: leave ROBINHOOD_MFA_SECRET unset.
# Seed once on VPS: docker compose exec -it bot uv run python -m app.cli.rh_login
# Pickle persists in data/rh-tokens (mounted to /root/.tokens). Never use: docker compose down -v
#
# Schedule (cron on host): scripts/startup_backfill.sh at 7 AM ET, scripts/evening_pause.sh at 8 PM ET
# TRADING_WINDOW_ENABLED=true limits live orders to 9:30 AM–4 PM ET during active worker window.
